{
  "name": "@ajgifford/keepwatching-common-server",
  "version": "0.14.0",
  "description": "Common utilities and services for KeepWatching API",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.mts",
      "import": "./dist/schema.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs"
    },
    "./context": {
      "types": "./dist/context.d.mts",
      "import": "./dist/context.mjs"
    },
    "./services": {
      "types": "./dist/services.d.mts",
      "import": "./dist/services.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "import": "./dist/utils.mjs"
    },
    "./logger": {
      "types": "./dist/logger.d.mts",
      "import": "./dist/logger.mjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.mts",
      "import": "./dist/middleware.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "rebuild": "yarn clean && yarn build",
    "prepare": "yarn build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --config ./.prettierrc.js . --write",
    "format:check": "prettier --config ./.prettierrc.js . --check",
    "type-check": "tsc --noEmit",
    "version:patch": "yarn version --patch",
    "version:minor": "yarn version --minor",
    "version:major": "yarn version --major"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajgifford/keepwatching-common-server.git"
  },
  "author": "Gifford Family Dev",
  "license": "ISC",
  "dependencies": {
    "@ajgifford/keepwatching-types": "^0.10.0",
    "axios": "1.14.0",
    "axios-retry": "^4.5.0",
    "cron-parser": "5.5.0",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "firebase-admin": "13.7.0",
    "fs": "^0.0.1-security",
    "ioredis": "^5.10.1",
    "mysql2": "3.20.0",
    "node-cache": "^5.1.2",
    "node-cron": "4.2.1",
    "nodemailer": "8.0.4",
    "socket.io": "^4.8.3",
    "streaming-availability": "^4.4.0",
    "uuid": "^13.0.0",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/express": "5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "11.0.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-jest": "^29.15.1",
    "jest": "^30.3.0",
    "jest-html-reporter": "^4.4.0",
    "jest-mock-extended": "^4.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "8.58.0"
  },
  "resolutions": {
    "punycode": "^2.3.1",
    "diff": ">=4.0.4",
    "node-fetch": "3.3.2",
    "node-forge": "^1.4.0",
    "whatwg-url": "16.0.1",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "body-parser": "^2.2.2",
    "jws": "4.0.1",
    "qs": "6.15.0",
    "lodash-es": "4.18.1",
    "minimatch": "10.2.5",
    "brace-expansion": ">=1.1.13",
    "fast-xml-parser": ">=5.3.4",
    "picomatch": ">=4.0.2",
    "path-to-regexp": "^8.4.0",
    "@typescript-eslint/utils": "^8.58.0",
    "handlebars": "^4.7.9",
    "flatted": "^3.4.2",
    "socket.io-parser": "^4.2.6"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
